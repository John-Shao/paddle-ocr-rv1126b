#!/bin/sh

APP_DIR=${APP_DIR:-/data/ppocr-text}
BIN="$APP_DIR/ppocrd"
PID=/var/run/ppocrd.pid
LOG=/var/log/ppocrd.log
SOCK=/run/ppocrd.sock

start() {
    if [ -f "$PID" ] && kill -0 "$(cat "$PID")" 2>/dev/null; then
        echo "ppocrd already running ($(cat "$PID"))"
        return 0
    fi
    if [ ! -x "$BIN" ]; then
        echo "missing executable: $BIN"
        return 1
    fi
    mkdir -p /run
    cd "$APP_DIR" || return 1
    echo "starting ppocrd"
    LD_LIBRARY_PATH=./lib:/usr/lib nohup "$BIN" --daemon --daemon-socket "$SOCK" >>"$LOG" 2>&1 &
    echo $! > "$PID"
}

stop() {
    if [ -f "$PID" ]; then
        pid=$(cat "$PID")
        if kill -0 "$pid" 2>/dev/null; then
            echo "stopping ppocrd ($pid)"
            kill "$pid"
            for i in 1 2 3 4 5; do
                kill -0 "$pid" 2>/dev/null || break
                sleep 1
            done
            kill -0 "$pid" 2>/dev/null && kill -9 "$pid"
        fi
        rm -f "$PID"
    fi
    rm -f "$SOCK"
}

status() {
    if [ -f "$PID" ] && kill -0 "$(cat "$PID")" 2>/dev/null; then
        echo "ppocrd: running ($(cat "$PID"))"
        return 0
    fi
    echo "ppocrd: stopped"
    return 3
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; start ;;
    status) status ;;
    *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac

